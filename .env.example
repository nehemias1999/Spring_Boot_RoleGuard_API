# ============================================================
# RoleGuard API — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit a .env file with real secrets.
# ============================================================

# ─── Database ──────────────────────────────────────────────
# MySQL credentials for the roleguard_db database.
# The URL is already hardcoded in application.yaml; override here if needed.
DB_USERNAME=root
DB_PASSWORD=changeme

# ─── JWT ───────────────────────────────────────────────────
# HMAC-SHA256 signing key for access tokens.
# Must be Base64-encoded and at least 32 bytes (256 bits) when decoded.
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_STRONG_BASE64_ENCODED_SECRET_OF_AT_LEAST_256_BITS

# Access token lifetime in milliseconds (default: 86400000 = 24 hours).
# For production, consider a shorter value (e.g. 900000 = 15 minutes) combined
# with the refresh token mechanism.
# JWT_EXPIRATION_MS=86400000

# Refresh token lifetime in milliseconds (default: 604800000 = 7 days).
# JWT_REFRESH_EXPIRATION_MS=604800000
